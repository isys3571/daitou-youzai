<footer style="background:#f0f0f0; border-top:1px solid #e5e5e5;">
  <div class="container">

    <div class="py-10 md:py-12 flex flex-col md:flex-row md:items-start md:justify-between gap-8 md:gap-12"
         style="border-bottom:1px solid #e0e0e0;">

      <!-- 会社情報 -->
      <div>
        <div class="font-display text-primary text-lg mb-3">大東熔材株式会社</div>
        <address class="font-sans text-sm leading-7 not-italic" style="color:#888;">
          {{ site.address }}<br>
          TEL：<a href="tel:{{ site.tel }}"
                 class="hover:text-accent transition-colors" style="color:#888;">{{ site.tel }}</a>
        </address>
      </div>

      <!-- ナビ -->
      <nav class="flex flex-col gap-2.5">
        <a href="/"             class="font-sans text-sm transition-colors hover:text-accent" style="color:#888;">トップページ</a>
        <a href="/shohin/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:#888;">取扱商品</a>
        <a href="/kaisha-joho/" class="font-sans text-sm transition-colors hover:text-accent" style="color:#888;">会社情報</a>
        <a href="/access/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:#888;">アクセス</a>
        <a href="/contact/"     class="font-sans text-sm transition-colors hover:text-accent" style="color:#888;">お問い合わせ</a>
      </nav>

    </div>

    <div class="py-5">
      <p class="font-sans text-xs" style="color:#bbb;">&copy; {{ site.name }}. All rights reserved.</p>
    </div>

  </div>
</footer>
