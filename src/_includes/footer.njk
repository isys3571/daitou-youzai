<footer style="background:#eeebe6; border-top:1px solid rgba(0,0,0,.07);">
  <div class="container">

    <div class="py-10 md:py-12 flex flex-col md:flex-row md:items-start md:justify-between gap-8 md:gap-12"
         style="border-bottom:1px solid rgba(0,0,0,.07);">

      <!-- 会社情報 -->
      <div>
        <div class="font-display text-primary text-lg mb-3">大東熔材株式会社</div>
        <address class="font-sans text-sm leading-7 not-italic" style="color:#706a63;">
          {{ site.address }}<br>
          TEL：<a href="tel:{{ site.tel }}"
                 class="hover:text-accent transition-colors" style="color:#706a63;">{{ site.tel }}</a>
        </address>
      </div>

      <!-- ナビ -->
      <nav class="flex flex-col gap-2.5">
        <a href="/"             class="font-sans text-sm transition-colors hover:text-accent" style="color:#706a63;">トップページ</a>
        <a href="/shohin/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:#706a63;">取扱商品</a>
        <a href="/kaisha-joho/" class="font-sans text-sm transition-colors hover:text-accent" style="color:#706a63;">会社情報</a>
        <a href="/access/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:#706a63;">アクセス</a>
        <a href="/contact/"     class="font-sans text-sm transition-colors hover:text-accent" style="color:#706a63;">お問い合わせ</a>
      </nav>

    </div>

    <div class="py-5">
      <p class="font-sans text-xs" style="color:#918b85;">&copy; {{ site.name }}. All rights reserved.</p>
    </div>

  </div>
</footer>
