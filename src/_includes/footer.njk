<footer style="background:#1a2633;">
  <div class="container">

    <div class="py-10 md:py-12 flex flex-col md:flex-row md:items-start md:justify-between gap-8 md:gap-12"
         style="border-bottom:1px solid rgba(255,255,255,.1);">

      <!-- 会社情報 -->
      <div>
        <div class="font-display text-white text-lg mb-3">大東熔材株式会社</div>
        <address class="font-sans text-sm leading-7 not-italic" style="color:rgba(255,255,255,.5);">
          {{ site.address }}<br>
          TEL：<a href="tel:{{ site.tel }}"
                 class="hover:text-accent transition-colors" style="color:rgba(255,255,255,.5);">{{ site.tel }}</a>
        </address>
      </div>

      <!-- ナビ -->
      <nav class="flex flex-col gap-2.5">
        <a href="/"             class="font-sans text-sm transition-colors hover:text-accent" style="color:rgba(255,255,255,.5);">トップページ</a>
        <a href="/shohin/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:rgba(255,255,255,.5);">取扱商品</a>
        <a href="/kaisha-joho/" class="font-sans text-sm transition-colors hover:text-accent" style="color:rgba(255,255,255,.5);">会社情報</a>
        <a href="/access/"      class="font-sans text-sm transition-colors hover:text-accent" style="color:rgba(255,255,255,.5);">アクセス</a>
        <a href="/contact/"     class="font-sans text-sm transition-colors hover:text-accent" style="color:rgba(255,255,255,.5);">お問い合わせ</a>
      </nav>

    </div>

    <div class="py-5">
      <p class="font-sans text-xs" style="color:rgba(255,255,255,.3);">&copy; {{ site.name }}. All rights reserved.</p>
    </div>

  </div>
</footer>
