<header class="sticky top-0 z-40 bg-white border-b border-gray-100">
  <div class="container">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- ロゴ -->
      <a href="/" class="flex items-baseline gap-1.5 group">
        <span class="font-display text-primary text-2xl md:text-3xl font-bold leading-none">大東熔材</span>
        <span class="font-sans text-primary/60 text-sm md:text-lg tracking-wider">株式会社</span>
      </a>

      <!-- デスクトップナビ -->
      <nav class="hidden md:flex items-center">
        <a href="/kaisha-joho/"
           class="font-sans text-sm tracking-wide px-6 py-2 transition-colors duration-200 {% if activePage == 'kaisha-joho' %}text-primary font-medium{% else %}text-body hover:text-primary{% endif %}">
          会社情報
        </a>
        <span class="w-px h-4" style="background:#ddd;"></span>
        <a href="/shohin/"
           class="font-sans text-sm tracking-wide px-6 py-2 transition-colors duration-200 {% if activePage == 'shohin' %}text-primary font-medium{% else %}text-body hover:text-primary{% endif %}">
          取扱商品
        </a>
        <span class="w-px h-4" style="background:#ddd;"></span>
        <a href="/access/"
           class="font-sans text-sm tracking-wide px-6 py-2 transition-colors duration-200 {% if activePage == 'access' %}text-primary font-medium{% else %}text-body hover:text-primary{% endif %}">
          アクセス
        </a>
        <a href="/contact/"
           class="font-sans text-xs bg-primary text-white px-5 py-2 hover:bg-accent transition-colors duration-200 ml-3">
          お問い合わせ
        </a>
      </nav>

      <!-- ハンバーガー（モバイル） -->
      <button
        @click.prevent="mobileMenuOpen = !mobileMenuOpen"
        class="md:hidden p-2 text-primary"
        aria-label="メニューを開く"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path x-show="!mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path x-show="mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" style="display:none"/>
        </svg>
      </button>

    </div>
  </div>
</header>
