<nav
  id="mobile-nav"
  class="fixed top-0 left-0 h-full w-[280px] z-50 -translate-x-full transition-transform duration-300 md:hidden"
  class="bg-dark"
  :class="{ '-translate-x-full': !mobileMenuOpen, 'translate-x-0': mobileMenuOpen }"
>
  <div class="flex flex-col h-full">

    <!-- ヘッダー -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-white/10">
      <span class="font-display text-cream text-xl font-bold">大東熔材株式会社</span>
      <button @click="mobileMenuOpen = false" class="text-cream/50 hover:text-cream transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- メニュー -->
    <div class="flex-1 overflow-y-auto">
      {% set navItems = [
        { href: "/",             label: "トップページ", key: "home" },
        { href: "/shohin/",      label: "取扱商品",     key: "shohin" },
        { href: "/kaisha-joho/", label: "会社情報",     key: "kaisha-joho" },
        { href: "/access/",      label: "アクセス",     key: "access" },
        { href: "/contact/",     label: "お問い合わせ", key: "contact" }
      ] %}
      {% for item in navItems %}
        <a href="{{ item.href }}"
           class="flex items-center justify-between px-6 py-4 font-sans text-sm border-b border-white/10 transition-colors
                  {% if activePage == item.key %}text-accent bg-white/5{% else %}text-cream hover:bg-white/5{% endif %}"
           {% if activePage == item.key %}style="border-left:3px solid"{% endif %}>
          {{ item.label }}
          <svg class="w-4 h-4 {% if activePage == item.key %}text-accent{% else %}text-white/30{% endif %}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      {% endfor %}
    </div>

    <!-- フッター -->
    <div class="px-6 py-5 border-t border-white/10">
      <p class="text-cream/30 text-xs font-sans">{{ site.address }}</p>
      <a href="tel:{{ site.tel }}" class="text-cream/50 text-sm font-en mt-1 block hover:text-cream transition-colors">{{ site.tel }}</a>
    </div>

  </div>
</nav>
