{
  "name": "daitou-youzai",
  "version": "1.0.0",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/css/tailwind-input.css -o ./src/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i ./src/css/tailwind-input.css -o ./src/css/tailwind.css --watch",
    "dev": "npm run build:css && eleventy --serve",
    "build": "npm run build:css && eleventy && find _site -name '*.njk' -type f -exec sh -c 'mv \"$1\" \"${1%.njk}.html\"' _ {} \\; && cp -r _site/* . && rm -rf _site && eleventy",
    "clean": "rm -rf _site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "tailwindcss": "^3.4.18"
  }
}
